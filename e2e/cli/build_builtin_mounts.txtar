#         "header": decoded_jwt[0],
#         "payload": decoded_jwt[1],
#         "signature": decoded_jwt[2],
#         "raw": input.jwt
#     }
# }
#
# newinput = obj {
#     obj = object.union(input, {"context": jwt_context})
# } else = input
